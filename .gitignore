# Build artifacts (regenerated; never committed). No leading slash = in any subfolder.
target/
node_modules/
dist/

# Test artifacts (Playwright E2E: reports and traces, regenerated on each run)
playwright-report/
test-results/

# Node and mining engine binaries: built by CI for each system, not versioned
/src-tauri/binaries/*.exe
/src-tauri/binaries/*.dll
/src-tauri/binaries/bitcoind
/src-tauri/binaries/bitcoin-cli
/src-tauri/binaries/brisvia-worker
/src-tauri/binaries/*.viejo
/src-tauri/binaries/*.pre-mainnet
/src-tauri/binaries/*.bak

# Secrets / credentials (never commit)
*.key
*.pem
.env
*.cookie

# System files
.DS_Store
Thumbs.db
*.log

# Internal development docs (not committed to the public repo)
I18N_SPEC.md
PLAN.md
crates/brisvia-randomx/README.md
MEJORAS-PENDIENTES.md
PENDIENTES-SIN-PUBLICAR.md
LOGROS-50-DISENO.md

# Release/updater manifests generated locally (published as release assets, not versioned)
latest.json
latest_*.json

# Python bytecode from the tools/checkers (regenerated on each run)
__pycache__/
*.pyc

# Sealed validation evidence (per-run hashes and manifests; kept private, never versioned)
evidence/

# Internal docs/tools kept out of the public repo (pre-launch audit)
PROJECT_STATE.md
PRODUCT_CONTRACTS.md
tools/autorizar.py

# Website captures generated by tests/e2e/capturas.spec.js
shots-out/
