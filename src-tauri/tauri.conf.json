{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brisvia Miner",
  "version": "1.0.0",
  "identifier": "com.brisvia.miner",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Brisvia — Miner",
        "width": 1080,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "maximizable": false,
        "theme": "Dark",
        "backgroundColor": "#0B1117"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "category": "Utility",
    "publisher": "Brisvia",
    "shortDescription": "Mine Brisvia with your CPU and join the network.",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "resources": ["binaries/bitcoind.exe", "binaries/bitcoin-cli.exe", "binaries/brisvia-worker.exe"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/installer_icon.ico",
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBQkY1ODdCRTA5RjVBClJXUmFuK0I3V0w5S0FOdlJ2V3lGVUVaSThZejY5S2NOWFRMYWhzMkgzR3hkVjRGRDhpdldkWTVOCg==",
      "endpoints": [
        "https://github.com/brisvia/brisvia-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
