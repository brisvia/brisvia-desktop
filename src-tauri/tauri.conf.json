{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brisvia Minero",
  "version": "0.1.0",
  "identifier": "com.brisvia.miner",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Brisvia — Minero",
        "width": 980,
        "height": 680,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true,
        "backgroundColor": "#0B1117"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "publisher": "Brisvia",
    "shortDescription": "Mine Brisvia with your CPU and join the network.",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "resources": ["binaries/bitcoind.exe", "binaries/bitcoin-cli.exe", "binaries/brisvia-worker.exe"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
